# ========== 应用配置（必填） ==========
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here
API_HOST=0.0.0.0
API_PORT=8000

# ========== MongoDB（必填） ==========
# 方式一：使用完整 URI（推荐）
# 无认证（本地未开启 auth）：mongodb://localhost:27017/mnemo
# 有认证（开启 auth 后必须）：mongodb://用户名:密码@localhost:27017/mnemo?authSource=admin
MONGODB_URI=mongodb://localhost:27017/mnemo
MONGODB_DB_NAME=mnemo

# 方式二：不设 MONGODB_URI 时，用下面变量拼接
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_USERNAME=        # 开启认证时必填
# MONGODB_PASSWORD=        # 开启认证时必填
# MONGODB_AUTH_SOURCE=admin

# ========== Neo4j（可选，用于网络图谱等） ==========
# 密码需与 Neo4j 服务端一致。Neo4j 5.x 不允许密码为 neo4j，若用本仓库 docker-compose 启动则填 neo4j123
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ========== Redis（可选，用于缓存） ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========== Qdrant（向量库，可选） ==========
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ========== Ollama（本地模型） ==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_ANALYSIS_MODEL=qwen2.5:3b
# FORMULA_MODEL=gemma3:27b
# KNOWLEDGE_MODEL=gemma3:1b

# ========== 文件上传 ==========
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploads

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/mnemo-api.log

# ========== 阶段二：QueryPlanner（LLM 驱动 + 规则 fallback） ==========
# 规划模式：llm=LLM 驱动（默认），rules=纯规则 fallback
QUERY_PLANNER_MODE=llm
# LLM 规划使用的模型（留空则复用 LLM_MODEL）
PLANNER_MODEL=mimo-v2.5
# LLM 规划超时（秒），超时自动 fallback 到规则
PLANNER_TIMEOUT=20

# ========== 阶段三：EvidenceVerifier + Reflector ==========
VERIFIER_MODE=rules
VERIFIER_MODEL=mimo-v2.5
VERIFIER_TIMEOUT=15
VERIFIER_MIN_SCORE=0.01
REFLECTOR_MODE=rules
REFLECTOR_MODEL=mimo-v2.5
REFLECTOR_TIMEOUT=15
REFLECTOR_MIN_VERIFIED=2
REFLECTOR_MIN_TOP_SCORE=0.02

# MCP Client 配置
MCP_ENABLED=false
